{
  "manifest_version": 3,
  "name": "Sora Video Archiver",
  "version": "1.0.0",
  "description": "Download and archive all your Sora AI videos before the shutdown.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://sora.com/*",
    "https://sora.chatgpt.com/*",
    "https://api.openai.com/*",
    "https://videos.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sora.com/*", "https://sora.chatgpt.com/*"],
      "js": ["lib/constants.js", "lib/scraper.js", "content-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://sora.com/*", "https://sora.chatgpt.com/*"],
      "js": ["lib/constants.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
